# Skopiuj ten plik do .env i uzupełnij wartości.
# Plik .env jest ignorowany przez git — Twój klucz nigdy nie trafi do repozytorium.

# Klucz API Serper.dev (darmowy, 2500 zapytań, bez karty): https://serper.dev
# Używany do analizy treści vs konkurencja (TOP10 Google).
SERPER_API_KEY=

# (opcjonalnie) Port serwera, domyślnie 4317
# PORT=4317
